<section class="hero">
  <h1 class="wordmark" data-text="NOWAY">NOWAY</h1>
  <p class="tagline">creative tech</p>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    text-align: center;
  }

  .wordmark {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--size-wordmark);
    line-height: 1;
    padding-bottom: 0.15em;
    color: var(--color-text);
    letter-spacing: 0.02em;

    text-shadow:
      0 0 4px var(--color-accent-bleed),
      0 0 16px var(--color-accent-bleed),
      0 0 32px var(--color-accent),
      0 0 64px rgba(220, 20, 20, 0.35);

    /* Displacement filter warps the wordmark + its red bleed shadow,
       fed by the animated turbulence defined in BaseLayout — heat-shimmer
       look around the glow. */
    filter: url(#wordmark-distort);

    transition: text-shadow var(--duration-slow) var(--ease-slow);
    animation: wordmark-in 1200ms var(--ease-slow) both;
  }

  .wordmark::before,
  .wordmark::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    pointer-events: none;
    opacity: 0;
    text-shadow: none;
  }

  .wordmark:hover {
    text-shadow:
      0 0 6px var(--color-accent),
      0 0 24px var(--color-accent),
      0 0 56px var(--color-accent),
      0 0 96px rgba(220, 20, 20, 0.55);
    animation: wordmark-jitter 0.7s steps(1, end);
  }

  .wordmark:hover::before {
    color: var(--color-accent);
    animation: glitch-top 0.7s steps(1, end);
  }

  .wordmark:hover::after {
    color: var(--color-text);
    animation: glitch-bottom 0.7s steps(1, end);
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: var(--size-body);
    color: var(--color-text-dim);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: tagline-in 1400ms var(--ease-slow) 400ms both;
  }

  @keyframes wordmark-in {
    from { opacity: 0; filter: blur(20px); transform: scale(1.05); }
    to   { opacity: 1; filter: blur(0);    transform: scale(1); }
  }

  @keyframes tagline-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes wordmark-jitter {
    0%   { transform: translate(0, 0); }
    10%  { transform: translate(-2px, 1px) skewX(-2deg); }
    20%  { transform: translate(2px, -1px); }
    30%  { transform: translate(-1px, 2px) skewX(1deg); }
    40%  { transform: translate(3px, 0); }
    50%  { transform: translate(-2px, -2px); }
    60%  { transform: translate(1px, 1px) skewX(-1deg); }
    70%  { transform: translate(-3px, 0); }
    80%  { transform: translate(2px, 2px); }
    90%  { transform: translate(-1px, -1px); }
    100% { transform: translate(0, 0); }
  }

  @keyframes glitch-top {
    0%   { opacity: 0; clip-path: inset(0 0 100% 0); transform: translate(0, 0); }
    10%  { opacity: 1; clip-path: inset(0 0 75% 0); transform: translate(-4px, -2px); }
    20%  { opacity: 1; clip-path: inset(15% 0 60% 0); transform: translate(3px, -1px); }
    30%  { opacity: 1; clip-path: inset(5% 0 70% 0); transform: translate(-5px, 1px); }
    40%  { opacity: 1; clip-path: inset(25% 0 50% 0); transform: translate(4px, 0); }
    50%  { opacity: 0; clip-path: inset(0 0 100% 0); transform: translate(0, 0); }
    60%  { opacity: 1; clip-path: inset(10% 0 65% 0); transform: translate(-3px, 2px); }
    70%  { opacity: 1; clip-path: inset(35% 0 40% 0); transform: translate(2px, -2px); }
    80%  { opacity: 1; clip-path: inset(0 0 80% 0); transform: translate(-2px, 1px); }
    90%  { opacity: 0; clip-path: inset(0 0 100% 0); transform: translate(0, 0); }
    100% { opacity: 0; clip-path: inset(0 0 100% 0); transform: translate(0, 0); }
  }

  @keyframes glitch-bottom {
    0%   { opacity: 0; clip-path: inset(100% 0 0 0); transform: translate(0, 0); }
    10%  { opacity: 1; clip-path: inset(60% 0 15% 0); transform: translate(4px, 2px); }
    20%  { opacity: 1; clip-path: inset(75% 0 5% 0); transform: translate(-3px, 1px); }
    30%  { opacity: 1; clip-path: inset(50% 0 25% 0); transform: translate(5px, -1px); }
    40%  { opacity: 1; clip-path: inset(80% 0 0 0); transform: translate(-4px, 2px); }
    50%  { opacity: 0; clip-path: inset(100% 0 0 0); transform: translate(0, 0); }
    60%  { opacity: 1; clip-path: inset(40% 0 30% 0); transform: translate(3px, -2px); }
    70%  { opacity: 1; clip-path: inset(65% 0 10% 0); transform: translate(-2px, 2px); }
    80%  { opacity: 1; clip-path: inset(85% 0 0 0); transform: translate(2px, -1px); }
    90%  { opacity: 0; clip-path: inset(100% 0 0 0); transform: translate(0, 0); }
    100% { opacity: 0; clip-path: inset(100% 0 0 0); transform: translate(0, 0); }
  }
</style>
